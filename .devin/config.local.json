{
  "permissions": {
    "allow": [
      "Exec(devin mcp)",
      "Exec(find)",
      "Exec(cat)",
      "Exec(go get)",
      "Exec(go mod)",
      "Exec(go build)",
      "Exec(git add)",
      "Exec(mkdir)",
      "Exec(git commit)",
      "Exec(npm install)",
      "Exec(npm run)",
      "Exec(docker compose)",
      "Exec(go test)",
      "Exec(git checkout)",
      "Exec(git diff)",
      "Exec(git status)",
      "Exec(git log)",
      "Exec(grep nhooyr)",
      "Exec(python3)",
      "Exec(realpath)",
      "Exec(git push)",
      "Exec(npx playwright)",
      "Exec(git rev-parse)",
      "Exec(rm)",
      "Exec(grep)",
      "Exec(go vet)",
      "Exec(git merge)",
      "Exec(git stash)",
      "Exec(docker ps)",
      "Exec(docker inspect)",
      "Exec(psql)",
      "Exec(timeout go)",
      "Exec(ss)",
      "Exec(sudo ufw)",
      "Exec(curl)",
      "Exec(ping)",
      "Exec(npx next)"
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "transport": "stdio"
    }
  }
}