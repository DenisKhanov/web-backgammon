# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Имя базы данных (создаётся автоматически при первом запуске контейнера)
POSTGRES_DB=backgammon

# Пользователь БД
POSTGRES_USER=bg_user

# Пароль пользователя БД.
# Для локальной разработки можно оставить простой, например: dev_pass_123
# Для продакшена используйте криптостойкий пароль (32+ символов):
#   openssl rand -base64 32
POSTGRES_PASSWORD=change_me_in_production

# Внешний порт PostgreSQL при запуске через Docker Compose
POSTGRES_PORT=5433

# ─── Backend (Go) ─────────────────────────────────────────────────────────────
# Порт, на котором слушает Go-сервер
PORT=8080

# Внешний порт backend при запуске через Docker Compose
BACKEND_PORT=8080

# Строка подключения к PostgreSQL.
# Формат: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
# Для Docker: хост = "postgres" (имя сервиса), порт = 5432 (внутренний)
# Для локальной разработки: хост = "localhost", порт = 5433 (проброшен из Docker)
DATABASE_URL=postgres://bg_user:change_me_in_production@localhost:5433/backgammon?sslmode=disable

# Секрет для подписи session_token (cookie).
# Должен быть случайной строкой длиной не менее 32 символов.
# Генерация: openssl rand -hex 32
# ВНИМАНИЕ: Никогда не коммитьте реальное значение в репозиторий!
JWT_SECRET=change_me_to_random_64_char_string

# Разрешённые origins для CORS и WebSocket (через запятую).
# Для локальной разработки: http://localhost:3000
# Для продакшена: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Путь к директории с SQL-миграциями (относительно рабочей директории backend)
MIGRATIONS_DIR=migrations

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# URL REST API бэкенда (доступен из браузера)
NEXT_PUBLIC_API_URL=http://localhost:8080

# URL WebSocket бэкенда (доступен из браузера)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Внешний порт frontend при запуске через Docker Compose
FRONTEND_PORT=3000

# Сеть для Docker build. На серверах с нестандартным DNS можно поставить host.
DOCKER_BUILD_NETWORK=default
